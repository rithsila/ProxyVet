ipython_config.py

# pyenv
#   For a library or package, you might want to share your Python version
#   with other developers. For an app, this is know to cause problems.
# .python-version

# pipenv
#   According to pypa/pipenv#1053, Checkfile should be committed to VCS.
#   However, in some cases, users may see their Checkfile.lock in gitignore.
#   https://pipenv.pypa.io/en/latest/advanced/#pipenv-keep-out-of-vc-with-gitignore-not-recommended
#Checkfile.lock

# poetry
#   Using Poetry, the lock file should be committed to VCS, but the virtual env is not.
.venv/
poetry.lock

# pdm
#   Similar to Poetry, the lock file should be committed to VCS.
.pdm.toml
.pdm-plugins/
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath vars
*.sage.py

